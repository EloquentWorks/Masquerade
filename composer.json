{
    "name": "eloquent-works/masquerade",
    "description": "A feature-rich Laravel impersonation package with secure session handling, audit logs, middleware, events, and Blade helpers.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "impersonation",
        "impersonate",
        "masquerade",
        "admin",
        "audit",
        "eloquent-works"
    ],
    "authors": [
        {
            "name": "Eloquent Works"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/auth": "^11.15|^12.0|^13.0",
        "illuminate/contracts": "^11.15|^12.0|^13.0",
        "illuminate/database": "^11.15|^12.0|^13.0",
        "illuminate/encryption": "^11.15|^12.0|^13.0",
        "illuminate/http": "^11.15|^12.0|^13.0",
        "illuminate/routing": "^11.15|^12.0|^13.0",
        "illuminate/support": "^11.15|^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.10",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "EloquentWorks\\Masquerade\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "EloquentWorks\\Masquerade\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "EloquentWorks\\Masquerade\\MasqueradeServiceProvider"
            ],
            "aliases": {
                "Masquerade": "EloquentWorks\\Masquerade\\Facades\\Masquerade"
            }
        }
    },
    "scripts": {
        "format": "pint",
        "format:test": "pint --test",
        "analyse": "phpstan analyse --memory-limit=1G",
        "test": "phpunit",
        "quality": [
            "@format:test",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
